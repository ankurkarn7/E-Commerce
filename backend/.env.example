# Backend environment variables
# Copy this file to ".env" and fill in real values for production.
# For LOCAL development you can instead run `npm run dev`, which starts an
# in-memory MongoDB and sets MONGO_URI/JWT_SECRET automatically — no .env needed.

# MongoDB connection string (e.g. a MongoDB Atlas URI)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<dbname>

# Secret used to sign JWT auth tokens. Use a long, random string.
JWT_SECRET=replace-with-a-long-random-secret

# Port the server listens on (optional, defaults to 3000)
PORT=3000

# Set to "production" when deployed. This makes auth cookies Secure + SameSite=None
# (required for cross-site HTTPS). Leave unset/anything else for local http.
NODE_ENV=production
